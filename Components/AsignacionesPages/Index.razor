@page "/Index"
@using Microsoft.AspNetCore.Components.QuickGrid
@using Raydelis_HilarioAP1_P2.Models
@using Raydelis_HilarioAP1_P2.Services
@inject AsignacionService asignacionService
@inject EstudiantesService estudiantesService

<PageTitle>Listado asignaciones</PageTitle>
<div class="container">
    <div class="card shadow-lg">
        <div class="card-header bg-light d-flex justify-content-between">
            <h5 class="card-title">Asignaciones de puntos</h5>
            <a href="/Crear" class="btn btn-primary">
                <span class="bi bi-plus-square mt-3"></span>
            </a>
        </div>
        <div class="card-body bg-light">
            <div class="d-flex  bg-light gap-2">
                @* Busqueda *@
                <div class="col">
                    <label><strong>Filtrar por estudiante:</strong></label>
                    <InputSelect class="form-select" @bind-Value="FiltroEstudiante">
                        <option value="0"> Seleccione un estudiante...</option>
                        @foreach (var estudiante in ListaEstudiantes)
                        {
                            <option value = "@estudiante.EstudianteId" > @estudiante.Nombres </option >
                        }
                    </InputSelect>
                </div>
                <div class="col">
                    <label><strong>Desde:</strong></label>
                    <InputDate class="form-control" @bind-Value="FechaDesde" />
                </div>
                <div class="col">
                    <label><strong>Hasta:</strong></label>
                    <InputDate class="form-control" @bind-Value="FechaHasta" />
                </div>
                <button class="btn btn-outline-primary bi bi-search me-2" @onclick="Buscar"></button>
            </div>
            <div class="mt-3 table-responsive">
                @* Tabla *@
                <QuickGrid TGridItem = "AsignacionesPuntos" Items="@ListaQuery" class="table table-striped table-hover table-bordered">
                    <PropertyColumn Property = "e => e.IdAsignacion" Title="Entrada Id" />
                    <PropertyColumn Property = "e => e.Fecha" Title="Fecha" />
                    <TemplateColumn Title = "Estudiante" >
                        @(ListaEstudiantes.FirstOrDefault(e => e.EstudianteId == context.EstudianteId)?.Nombres)
                    </TemplateColumn>
                    <PropertyColumn Property = "e => e.TotalPuntos" Title="Total puntos" />
                    <TemplateColumn Title = "Acciones" >
                        <a class="btn btn-sm btn-outline-primary"
                            href="@($"/Editar/{context.IdAsignacion}")">
                            <span class="bi bi-pencil-square"></span>
                        </a>
                    </TemplateColumn>
                </QuickGrid>
            </div>
        </div>
        <div class="card-footer bg-light d-flex justify-content-between">
            <label><strong>Cantidad:</strong> @ListaAsignaciones.Count</label>
            <label><strong>Total puntos:</strong> @TotalPuntos</label>
        </div>
    </div>
</div>

@code {
    public List<AsignacionesPuntos> ListaAsignaciones = new List<AsignacionesPuntos>();
    public IQueryable<AsignacionesPuntos> ListaQuery = Enumerable.Empty<AsignacionesPuntos>().AsQueryable();
    public List<Estudiantes> ListaEstudiantes = new List<Estudiantes>();

    double TotalPuntos = 0.0;
    public int? FiltroEstudiante { get; set; }
    public DateTime? FechaDesde { get; set; }
    public DateTime? FechaHasta { get; set; }

    protected override async Task OnInitializedAsync()
    {
        ListaAsignaciones = await asignacionService.Listar(criterio: e => e.IdAsignacion > 0);
        ListaEstudiantes = await estudiantesService.Listar(criterio: e => e.EstudianteId > 0);

        if (ListaAsignaciones.Count > 0)
        {
            FechaDesde = ListaAsignaciones.Min(e => e.Fecha).Date;
            FechaHasta = ListaAsignaciones.Max(e => e.Fecha).Date;
            TotalPuntos = ListaAsignaciones.Sum(e => e.DetallesAsignacion.Sum(c => c.CantidadPuntos));
        }
        ListaQuery = ListaAsignaciones.AsQueryable();
    }

    private async Task Buscar()
    {
        var lista = ListaAsignaciones.AsQueryable();

        if (FiltroEstudiante.HasValue)
            lista = lista.Where(e => e.EstudianteId == FiltroEstudiante);

        if (FechaDesde.HasValue)
            lista = lista.Where(e => e.Fecha.Date >= FechaDesde.Value.Date);

        if (FechaHasta.HasValue)
            lista = lista.Where(e => e.Fecha.Date <= FechaHasta.Value.Date);

        ListaQuery = lista;
        TotalPuntos = ListaAsignaciones.Sum(e => e.DetallesAsignacion.Sum(d => d.CantidadPuntos));
    }
}
