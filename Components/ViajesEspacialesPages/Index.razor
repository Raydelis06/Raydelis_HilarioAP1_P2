@page "/Index"
@using Microsoft.AspNetCore.Components.QuickGrid
@using Raydelis_HilarioAP1_P2.Models

<div class="container">
    <div class="card shadow-lg">
        <div class="card-header bg-light d-flex justify-content-between">
            <h5 class="card-title">Viajes Espaciales</h5>
            <a href="/Crear" class="btn btn-primary">
                <span class="bi bi-plus-square mt-3"></span>
            </a>
        </div>
        <div class="card-body bg-light">
            <div class="d-flex  bg-light gap-2">
                @* Busqueda *@
                @* <InputNumber class="form-control" @bind-Value="FiltroId" placeholder="Filtrar por Id" />
                <button class="btn btn-outline-primary bi bi-search me-2" @onclick="Buscar"></button> *@
            </div>
            @* Tabla *@
            <div class="mt-3 table-responsive">
                <QuickGrid TGridItem="ViajesEspaciales" Items="@ListaQuery" class="table table-hover">
                    <PropertyColumn Property="e => e.ViajeId" Title="Entrada Id" />
                    <PropertyColumn Property="e => e.FechaViaje" Title="Fecha" />
                    <PropertyColumn Property="e => e.Descripcion" Title="Descripcion"  />
                    <PropertyColumn Property="e => e.Costo" Title="Costo" />
                    <TemplateColumn Title="Acciones">
                        <a class="btn btn-sm btn-outline-primary"
                           href="@($"/Editar/{context.ViajeId}")">
                            <span class="bi bi-pencil-square"></span>
                        </a>
                    </TemplateColumn>

                </QuickGrid>
            </div>
        </div>
        <div class="card-footer bg-light d-flex justify-content-between">
            
        </div>
    </div>
</div>

@code {
    public IQueryable<ViajesEspaciales> ListaQuery = Enumerable.Empty<ViajesEspaciales>().AsQueryable();
}
