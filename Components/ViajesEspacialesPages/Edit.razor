@page "/Editar/{IdEntrada:int}"
@using Raydelis_HilarioAP1_P2.DAL
@using Raydelis_HilarioAP1_P2.Models
@using System.ComponentModel.DataAnnotations

@inject ToastService toastService
@inject NavigationManager navigationManager

<PageTitle>Editar viaje</PageTitle>
<EditForm Model="@viaje" OnValidSubmit="Guardar">
    <DataAnnotationsValidator />
    <div class="container">
        <div class="card shadow-lg">
            <div class="card-header bg-light">
                <h5 class="card-title">Editar viaje</h5>
            </div>
            <div class="card-body bg-light">
                <div class="justify-content-between">
                    @* fecha *@
                    <label><strong>Fecha de viaje:</strong></label>
                    <div class="d-flex justify-content-start gap-2 mt-2">
                        <InputDate Type="InputDateType.DateTimeLocal" class="form-control" @bind-Value="@viaje.FechaViaje" placeholder="Ingrese la fecha del viaje..."></InputDate>
                        <ValidationMessage For="@(() => viaje.FechaViaje)" />
                    </div>

                    @* detalle *@
                    <h5 class="mt-4"><strong>Detalle de la entrada:</strong></h5>
                    <div class="border border-success p-3 mb-3 mt-2">
                        <div class="row d-flex justify-content-between">
                            <div class="col">
                                <label>Tipo detalle:</label>
                                <InputSelect class="form-select" @bind-Value="viaje.FechaViaje">
                                    <option value="0">Seleccione un tipo...</option>
                                </InputSelect>
                            </div>
                            <div class="col d-flex align-items-end">
                                <button type="button" class="btn btn-outline-primary bi bi-plus">Agregar</button>
                            </div>
                        </div>
                        <div class="mt-3 table-responsive">
                            <table class="table table-hover">
                                <thead class="table-light">
                                    <tr>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <th></th>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-footer d-flex justify-content-center gap-2">
                <a href="/Index" class="btn btn-secondary ">
                    <span class="bi bi-arrow-left"> Volver</span>
                </a>
                <button type="submit" class="btn btn-primary bi bi-save"> Crear</button>
                <button class="btn btn-danger bi bi-trash" @onclick="Eliminar">Eliminar</button>
            </div>
        </div>
    </div>
</EditForm>

@code {
    [Parameter]
    public int ViajeId { get; set; } = 0;
    ViajesEspaciales viaje = new();

    protected override async Task OnInitializedAsync()
    { }

    public async Task Guardar()
    {

    }
    public async Task Eliminar()
    {

    }
}
