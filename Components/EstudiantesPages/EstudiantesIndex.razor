@page "/EstudiantesIndex"
@using Microsoft.AspNetCore.Components.QuickGrid
@using Raydelis_HilarioAP1_P2.Models
@using Raydelis_HilarioAP1_P2.Services
@inject AsignacionService asignacionService
@inject EstudiantesService estudiantesService

<PageTitle>Listado estudiantes</PageTitle>
<div class="container">
    <div class="card shadow-lg">
        <div class="card-header bg-light d-flex justify-content-between">
            <h5 class="card-title">Estudiantes registrados</h5>
        </div>
        <div class="card-body bg-light">
            <div class="mt-3 table-responsive">
                @* Tabla *@
                <QuickGrid TGridItem="Estudiantes" Items="@ListaQuery" class="table table-striped table-hover table-bordered">
                    <PropertyColumn Property="e => e.EstudianteId" Title="Estudiante Id" />
                    <PropertyColumn Property="e => e.Nombres" Title="Nombres" />
                    <PropertyColumn Property="e => e.Email" Title="Email" />
                    <PropertyColumn Property="e => e.Edad" Title="Edad" />
                    <PropertyColumn Property="e => e.BalancePuntos" Title="Balance puntos" />

                </QuickGrid>
            </div>
        </div>
        <div class="card-footer bg-light d-flex justify-content-between">
            <label><strong>Cantidad:</strong> @ListaEstudiantes.Count</label>
        </div>
    </div>
</div>

@code {
    public IQueryable<Estudiantes> ListaQuery = Enumerable.Empty<Estudiantes>().AsQueryable();
    public List<Estudiantes> ListaEstudiantes = new List<Estudiantes>();

    protected override async Task OnInitializedAsync()
    {
        ListaEstudiantes = await estudiantesService.Listar(criterio: e => e.EstudianteId > 0);
        ListaQuery = ListaEstudiantes.AsQueryable();
    }
}

